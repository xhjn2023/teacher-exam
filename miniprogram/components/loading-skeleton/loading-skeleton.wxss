/* 骨架屏 */
.skeleton {
  padding: 20rpx 0;
}

/* 骨架闪烁动画 */
@keyframes skShimmer {
  0%   { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.sk-line,
.sk-avatar,
.sk-block {
  background: linear-gradient(90deg, #E8ECEA 25%, #DDE4E2 50%, #E8ECEA 75%);
  background-size: 200% 100%;
  animation: skShimmer 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}

/* list 布局 */
.sk-row {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}

.sk-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.sk-lines {
  flex: 1;
}

.sk-line {
  height: 28rpx;
  margin-bottom: 12rpx;
}

.sk-line.w100 { width: 100%; }
.sk-line.w90  { width: 90%; }
.sk-line.w80  { width: 80%; }
.sk-line.w60  { width: 60%; }
.sk-line.w70  { width: 70%; }

/* card 布局 */
.sk-card {
  width: 100%;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* detail 布局 */
.sk-detail {
  padding: 24rpx;
}

.sk-title {
  height: 40rpx !important;
  margin-bottom: 24rpx;
}

.sk-block {
  width: 100%;
  height: 240rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}
