/* 选项条目 */
.opt-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  margin-bottom: 12rpx;
  border-radius: 12rpx;
  border: 2rpx solid #E8ECEA;
  background: #F2F4F3;
  transition: all 0.2s ease;
}

.opt-item.selected {
  border-color: #5B8C7E;
  background: #E8F0EE;
}

.opt-item.correct {
  border-color: #5B8C7E;
  background: #E8F0EE;
}

.opt-item.wrong {
  border-color: #D96C6C;
  background: #FDEDED;
}

.opt-label {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #5B8C7E;
  background: #E8F0EE;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.opt-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-all;
}

.opt-icon {
  font-size: 28rpx;
  font-weight: 700;
  margin-left: 12rpx;
  color: #5B8C7E;
  flex-shrink: 0;
}

.opt-item.wrong .opt-icon {
  color: #D96C6C;
}
