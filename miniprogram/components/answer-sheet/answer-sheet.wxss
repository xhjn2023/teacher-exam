/* 答题卡浮层 */
.sheet-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 999;
  display: none;
  animation: sheetFadeIn 0.3s ease;
}

.sheet-overlay.show {
  display: block;
}

@keyframes sheetFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.sheet-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.45);
}

.sheet-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  animation: sheetUp 0.3s ease;
}

@keyframes sheetUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #E8ECEA;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.sheet-close {
  font-size: 32rpx;
  color: #999;
  padding: 4rpx 8rpx;
}

/* 题号网格 */
.sheet-body {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx 28rpx;
  gap: 16rpx;
}

.sheet-num {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
  color: #555;
  border-radius: 50%;
  background: #F2F4F3;
  border: 2rpx solid #E8ECEA;
  transition: all 0.2s ease;
}

.sheet-num.current {
  color: #fff;
  background: #5B8C7E;
  border-color: #5B8C7E;
}

.sheet-num.done-correct {
  color: #fff;
  background: #5B8C7E;
  border-color: #5B8C7E;
}

.sheet-num.done-wrong {
  color: #fff;
  background: #D96C6C;
  border-color: #D96C6C;
}

.sheet-num.done-answered {
  color: #5B8C7E;
  background: #E8F0EE;
  border-color: #5B8C7E;
}

/* 底部 */
.sheet-footer {
  padding: 20rpx 32rpx 40rpx;
}

.sheet-submit-btn {
  text-align: center;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  color: #fff;
  background: #D96C6C;
  border-radius: 44rpx;
}
