/* 题目卡片 */
.q-card {
  min-height: 280rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* 题号区 */
.q-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.q-index {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 12rpx;
}

.q-type.tag {
  font-size: 22rpx;
  color: #fff;
  background: #5B8C7E;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.flex-1 { flex: 1; }

.favorite-btn {
  font-size: 36rpx;
  color: #ccc;
  padding: 4rpx 8rpx;
}

.favorite-btn .fav-active {
  color: #FFB74D;
}

/* 题干 */
.q-title {
  font-size: 30rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 20rpx;
  word-break: break-all;
}

/* 选项区 */
.q-options {
  margin-bottom: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  margin-bottom: 12rpx;
  border-radius: 12rpx;
  border: 2rpx solid #E8ECEA;
  background: #F2F4F3;
  transition: all 0.2s ease;
}

.option-item.selected {
  border-color: #5B8C7E;
  background: #E8F0EE;
}

.option-item.correct {
  border-color: #5B8C7E;
  background: #E8F0EE;
}

.option-item.wrong {
  border-color: #D96C6C;
  background: #FDEDED;
}

.option-label {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #5B8C7E;
  background: #E8F0EE;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.option-icon {
  font-size: 28rpx;
  font-weight: 700;
  margin-left: 12rpx;
  color: #5B8C7E;
}

.option-item.wrong .option-icon {
  color: #D96C6C;
}

/* 填空题 */
.q-fill {
  margin-bottom: 16rpx;
}

.fill-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #DDE4E2;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.fill-answer {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.text-secondary { color: #888; font-size: 26rpx; }
.text-primary   { color: #5B8C7E; font-size: 26rpx; }

/* 判断题 */
.q-judge-btns {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.judge-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  background: #F2F4F3;
  border-radius: 12rpx;
  border: 2rpx solid #E8ECEA;
  transition: all 0.2s ease;
}

.judge-btn.selected {
  color: #fff;
  background: #5B8C7E;
  border-color: #5B8C7E;
}

/* 主观题 */
.q-essay {
  margin-bottom: 16rpx;
}

.essay-textarea {
  width: 100%;
  min-height: 160rpx;
  border: 2rpx solid #DDE4E2;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 解析区 */
.q-analysis {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #E8ECEA;
}

.analysis-header {
  margin-bottom: 12rpx;
}

.analysis-flag {
  display: inline-block;
  padding: 6rpx 20rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
}

.analysis-flag.correct {
  color: #5B8C7E;
  background: #E8F0EE;
}

.analysis-flag.wrong {
  color: #D96C6C;
  background: #FDEDED;
}

.analysis-content {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.knowledge-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 操作区 */
.q-actions {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.action-btn {
  padding: 16rpx 60rpx;
  font-size: 28rpx;
  color: #fff;
  background: #5B8C7E;
  border-radius: 40rpx;
  text-align: center;
}

/* 已回答状态微调 */
.q-card.answered { opacity: 1; }

/* 题目报错入口 */
.report-entry {
  display: inline-block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #888;
  padding: 4rpx 0;
}

.report-entry:active {
  color: #5B8C7E;
}

/* 报错弹窗 */
.report-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.report-popup {
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  box-sizing: border-box;
}

.report-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.report-section-label {
  font-size: 26rpx;
  color: #555;
  margin-top: 8rpx;
  margin-bottom: 12rpx;
}

.report-type-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.report-type-item {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: #555;
  background: #F2F4F3;
  border: 2rpx solid #E8ECEA;
  border-radius: 28rpx;
}

.report-type-item.selected {
  color: #fff;
  background: #5B8C7E;
  border-color: #5B8C7E;
}

.report-textarea {
  width: 100%;
  min-height: 140rpx;
  border: 2rpx solid #DDE4E2;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.report-placeholder {
  color: #bbb;
}

.report-btns {
  display: flex;
  gap: 20rpx;
}

.report-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 38rpx;
}

.report-btn.cancel {
  color: #666;
  background: #F2F4F3;
}

.report-btn.submit {
  color: #fff;
  background: #5B8C7E;
}

.report-btn.submit.disabled {
  opacity: 0.6;
}
