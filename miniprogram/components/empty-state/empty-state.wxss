/* 空白页占位 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  animation: emptyFadeIn 0.4s ease;
}

@keyframes emptyFadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 28rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
  text-align: center;
}

.empty-subtitle {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 18rpx 60rpx;
  font-size: 28rpx;
  color: #fff;
  background: #5B8C7E;
  border-radius: 40rpx;
  text-align: center;
}
