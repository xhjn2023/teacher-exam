.page {
  min-height: 100vh;
  padding-bottom: 24rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border);
}

.search-input-wrap {
  flex: 1;
  position: relative;
}

.search-input {
  width: 100%;
  height: 68rpx;
  background: var(--bg-page);
  border-radius: 36rpx;
  padding: 0 70rpx 0 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.search-clear {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-hint);
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.06);
}

.search-btn {
  padding: 14rpx 32rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.search-btn:active {
  opacity: 0.85;
}

/* 结果列表 */
.results {
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-item {
  padding: 24rpx;
  transition: transform 0.15s ease;
}

.result-item:active {
  transform: scale(0.99);
}

.result-content {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.load-more {
  padding: 28rpx 0;
  text-align: center;
}

/* 搜索中 */
.searching {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--primary);
  animation: bounce 1.4s ease-in-out infinite both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
.dot:nth-child(3) { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* 搜索提示 */
.search-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.hint-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.hint-text {
  font-size: 28rpx;
  text-align: center;
  line-height: 1.6;
}
