/* 首页 */

.hero {
  background: linear-gradient(135deg, #5B8C7E, #3F6F62);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin: 20rpx 24rpx;
  color: #fff;
}
.hero-title { font-size: 40rpx; font-weight: 700; margin-bottom: 8rpx; }
.hero-sub { font-size: 26rpx; opacity: 0.85; margin-bottom: 24rpx; }
.hero-stats { display: flex; align-items: center; gap: 24rpx; }
.stat-item { text-align: center; flex: 1; }
.stat-num { display: block; font-size: 44rpx; font-weight: 800; }
.stat-label { font-size: 22rpx; opacity: 0.75; margin-top: 4rpx; }
.stat-divider { width: 1rpx; height: 50rpx; background: rgba(255,255,255,0.3); }

.section { padding: 0 24rpx; margin-top: 32rpx; }
.section-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 16rpx; }

.exam-grid { display: flex; gap: 16rpx; }
.exam-item { flex: 1; text-align: center; padding: 32rpx 16rpx; display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.exam-item:active { opacity: 0.8; }
.exam-icon { width: 80rpx; height: 80rpx; border-radius: 20rpx; }
.exam-name { font-size: 28rpx; font-weight: 600; }
.exam-desc { font-size: 22rpx; color: var(--text-hint); }

.quick-grid { display: flex; gap: 16rpx; }
.quick-item { flex: 1; text-align: center; padding: 28rpx; }
.quick-icon { font-size: 48rpx; }
.quick-label { font-size: 26rpx; margin-top: 8rpx; display: block; color: var(--text-secondary); }
