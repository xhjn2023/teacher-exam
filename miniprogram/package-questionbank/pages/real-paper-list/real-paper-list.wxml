<view class="page">
  <view class="list">
    <view class="paper-card card" wx:for="{{papers}}" wx:key="_id" bindtap="onItemTap" data-item="{{item}}">
      <view class="flex-between">
        <view class="flex-1">
          <view class="paper-header flex-row gap-md">
            <view class="paper-year" wx:if="{{item.year}}">{{item.year}}</view>
            <view class="paper-title">{{item.title || item.name}}</view>
          </view>
          <view class="flex-row gap-sm mt-sm" wx:if="{{item.questionCount !== undefined || item.duration}}">
            <text class="tag" wx:if="{{item.questionCount !== undefined}}">{{item.questionCount}}题</text>
            <text class="tag tag-accent" wx:if="{{item.duration}}">{{item.duration}}分钟</text>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>
  </view>

  <view wx:if="{{loadingMore}}" class="load-more">
    <text class="text-hint text-sm">加载中…</text>
  </view>
  <view wx:if="{{noMore && papers.length > 0}}" class="load-more">
    <text class="text-hint text-sm">— 已经到底了 —</text>
  </view>

  <empty-state wx:if="{{!loading && papers.length === 0}}" title="暂无真题套卷" subtitle="该科目暂未收录历年真题"></empty-state>

  <view wx:if="{{loading}}" class="skeleton-list">
    <view class="card skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="*this">
      <view class="skeleton skeleton-title"></view>
      <view class="skeleton skeleton-sub mt-sm"></view>
    </view>
  </view>
</view>
