.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
}

/* 顶部进度条 */
.progress-bar {
  padding: 16rpx 32rpx;
  background: var(--bg-card);
}

.progress-info {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.progress-num {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.progress-type {
  font-size: 22rpx;
  color: var(--text-hint);
}

.progress-track {
  height: 6rpx;
  background: var(--border);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-light));
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

/* 滚动区域 */
.scroll-wrap {
  flex: 1;
  overflow: hidden;
}

/* 加载状态 */
.loading-more {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
  color: var(--text-hint);
}

.no-more {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 底部工具栏 */
.bottom-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--bg-card);
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.04);
}

.bar-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  border-radius: var(--radius);
  background: var(--bg-page);
  color: var(--text-secondary);
  transition: all 0.2s;
}

.bar-btn:first-child {
  margin-right: 20rpx;
}

.bar-btn.primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-deep));
  color: #FFFFFF;
  font-weight: 500;
}

.bar-btn:active {
  opacity: 0.8;
}

.bar-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}
