<view class="page">
  <view class="list">
    <view class="subject-card card" wx:for="{{subjects}}" wx:key="_id" bindtap="onItemTap" data-item="{{item}}">
      <view class="flex-between">
        <view class="flex-1">
          <view class="subject-name">{{item.name}}</view>
          <view class="flex-row gap-sm mt-sm" wx:if="{{item.questionCount !== undefined || item.chapterCount !== undefined}}">
            <text class="tag" wx:if="{{item.chapterCount !== undefined}}">{{item.chapterCount}}个章节</text>
            <text class="tag tag-accent" wx:if="{{item.questionCount !== undefined}}">{{item.questionCount}}题</text>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>
  </view>

  <empty-state wx:if="{{!loading && subjects.length === 0}}" title="暂无科目" subtitle="该考试类型下暂未添加科目"></empty-state>

  <view wx:if="{{loading}}" class="skeleton-list">
    <view class="card skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="*this">
      <view class="skeleton skeleton-title"></view>
    </view>
  </view>
</view>
