<view class="page">
  <!-- 练习模式快捷入口 -->
  <view class="mode-bar">
    <view class="mode-item card" bindtap="onRandomPractice">
      <text class="mode-icon">🎲</text>
      <text class="mode-label">随机练习</text>
    </view>
    <view class="mode-item card" bindtap="onShowTypePicker">
      <text class="mode-icon">🏷️</text>
      <text class="mode-label">题型练习</text>
    </view>
  </view>

  <view class="list">
    <view class="chapter-card card" wx:for="{{chapters}}" wx:key="_id" bindtap="onChapterTap" data-item="{{item}}">
      <view class="flex-between">
        <view class="flex-row gap-md flex-1">
          <view class="chapter-icon" wx:if="{{item.type === 'real-paper'}}">{{'📋'}}</view>
          <view class="chapter-icon" wx:else>{{'📖'}}</view>
          <view class="flex-1">
            <view class="chapter-name">{{item.name}}</view>
            <view class="chapter-desc text-secondary text-sm" wx:if="{{item.desc}}">{{item.desc}}</view>
          </view>
        </view>
        <view class="flex-row gap-sm">
          <view class="badge" wx:if="{{item.questionCount !== undefined}}">{{item.questionCount}}题</view>
          <view class="arrow">›</view>
        </view>
      </view>
    </view>
  </view>

  <empty-state wx:if="{{!loading && chapters.length === 0}}" title="暂无章节" subtitle="该科目下暂未添加章节"></empty-state>

  <view wx:if="{{loading}}" class="skeleton-list">
    <view class="card skeleton-card" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
      <view class="skeleton skeleton-title"></view>
      <view class="skeleton skeleton-badge"></view>
    </view>
  </view>

  <!-- 题型选择弹窗 -->
  <view class="picker-mask" wx:if="{{showTypePicker}}" bindtap="onHideTypePicker">
    <view class="picker-content" catchtap>
      <view class="picker-title">选择题型练习</view>
      <view class="picker-item" wx:for="{{typeList}}" wx:key="value" bindtap="onTypePractice" data-item="{{item}}">
        <text class="picker-item-icon">🏷️</text>
        <text class="picker-item-label">{{item.label}}</text>
        <text class="picker-item-arrow">›</text>
      </view>
      <view class="picker-cancel" bindtap="onHideTypePicker">取消</view>
    </view>
  </view>
</view>
