.page {
  padding: 20rpx 24rpx;
  min-height: 100vh;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.chapter-card {
  padding: 24rpx;
  transition: transform 0.15s ease;
}

.chapter-card:active {
  transform: scale(0.98);
}

.chapter-icon {
  font-size: 36rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-pale);
  border-radius: 12rpx;
  flex-shrink: 0;
}

.chapter-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.4;
}

.chapter-desc {
  line-height: 1.4;
  margin-top: 4rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: var(--accent-pale);
  color: var(--accent);
  white-space: nowrap;
  flex-shrink: 0;
}

.arrow {
  font-size: 36rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

/* 骨架屏 */
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-card {
  padding: 24rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.skeleton-title {
  height: 32rpx;
  width: 55%;
}

.skeleton-badge {
  height: 28rpx;
  width: 80rpx;
  border-radius: 14rpx;
}
