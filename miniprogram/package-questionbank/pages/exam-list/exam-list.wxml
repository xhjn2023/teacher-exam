<view class="page">
  <view class="list">
    <view class="exam-card card" wx:for="{{examTypes}}" wx:key="_id" bindtap="onItemTap" data-item="{{item}}">
      <view class="flex-row gap-md">
        <image class="exam-icon" src="{{item.icon}}" mode="aspectFill" wx:if="{{item.icon}}"></image>
        <view class="flex-1">
          <view class="exam-name">{{item.name}}</view>
          <view class="exam-desc text-secondary text-sm" wx:if="{{item.desc}}">{{item.desc}}</view>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>
  </view>

  <empty-state wx:if="{{!loading && examTypes.length === 0}}" title="暂无考试类型" subtitle="联系管理员添加考试科目"></empty-state>

  <view wx:if="{{loading}}" class="skeleton-list">
    <view class="card skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
      <view class="skeleton skeleton-title"></view>
      <view class="skeleton skeleton-sub mt-sm"></view>
    </view>
  </view>
</view>
