<view class="page">
  <!-- 用户信息头部 -->
  <view class="user-header card">
    <view class="flex-row gap-md">
      <view class="avatar-wrapper" bindtap="onShowLogin" wx:if="{{!hasUserInfo}}">
        <view class="avatar-placeholder">�</view>
      </view>
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" wx:else></image>
      <view class="flex-1">
        <view class="user-name" wx:if="{{hasUserInfo}}">{{userInfo.nickName || '备考同学'}}</view>
        <view class="user-name" wx:else bindtap="onShowLogin">点击登录</view>
        <view class="user-motto text-sm text-hint">努力的人，运气不会差</view>
      </view>
    </view>
  </view>

  <!-- 学习统计 -->
  <view class="stats-bar" wx:if="{{studyData}}">
    <view class="stat-item">
      <view class="stat-num">{{studyData.totalDays || 0}}</view>
      <view class="stat-label">学习天数</view>
    </view>
    <view class="stat-item">
      <view class="stat-num">{{studyData.totalCount || 0}}</view>
      <view class="stat-label">已刷题</view>
    </view>
    <view class="stat-item">
      <view class="stat-num">{{studyData.correctRate || '0%'}}</view>
      <view class="stat-label">正确率</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item card" bindtap="goErrorBook">
      <view class="flex-between">
        <view class="flex-row gap-md">
          <view class="menu-icon">📝</view>
          <view>
            <view class="menu-title">错题本</view>
            <view class="menu-desc text-sm text-hint">温习错题，查漏补缺</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>

    <view class="menu-item card" bindtap="goFavorites">
      <view class="flex-between">
        <view class="flex-row gap-md">
          <view class="menu-icon">⭐</view>
          <view>
            <view class="menu-title">题目收藏</view>
            <view class="menu-desc text-sm text-hint">收藏喜欢的题目</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>

    <view class="menu-item card" bindtap="goStats">
      <view class="flex-between">
        <view class="flex-row gap-md">
          <view class="menu-icon">📊</view>
          <view>
            <view class="menu-title">学习数据</view>
            <view class="menu-desc text-sm text-hint">查看详细学习数据</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>

    <view class="menu-item card" bindtap="goSettings">
      <view class="flex-between">
        <view class="flex-row gap-md">
          <view class="menu-icon">⚙️</view>
          <view>
            <view class="menu-title">设置</view>
            <view class="menu-desc text-sm text-hint">缓存管理 · 关于我们</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>

    <!-- 退出登录（仅登录态可见） -->
    <view class="menu-item card logout-item" wx:if="{{hasUserInfo}}" bindtap="onLogout">
      <view class="flex-between">
        <view class="flex-row gap-md">
          <view class="menu-icon logout-icon">🚪</view>
          <view>
            <view class="menu-title logout-text">退出登录</view>
            <view class="menu-desc text-sm text-hint">清除当前账号登录态</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 登录弹窗 -->
  <view class="modal-mask" wx:if="{{showLoginModal}}" bindtap="onHideLogin">
    <view class="modal-content" catchtap>
      <view class="modal-title">登录</view>

      <!-- 头像选择 -->
      <view class="form-item">
        <view class="form-label">头像</view>
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="avatar-preview" src="{{tempUserInfo.avatarUrl || ''}}" mode="aspectFill" wx:if="{{tempUserInfo.avatarUrl}}"></image>
          <view class="avatar-placeholder" wx:else> 点击选择</view>
        </button>
      </view>

      <!-- 昵称输入 -->
      <view class="form-item">
        <view class="form-label">昵称</view>
        <input class="form-input" placeholder="请输入昵称" value="{{tempUserInfo.nickName}}" bindinput="onNicknameInput" maxlength="20" />
      </view>

      <!-- 按钮 -->
      <view class="modal-btns">
        <button class="btn btn-cancel" bindtap="onHideLogin">取消</button>
        <button class="btn btn-confirm" bindtap="onConfirmLogin">确认</button>
      </view>
    </view>
  </view>
</view>
