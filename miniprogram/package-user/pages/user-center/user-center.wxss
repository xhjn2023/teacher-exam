.page {
  padding: 24rpx;
  min-height: 100vh;
}

/* 用户头部 */
.user-header {
  padding: 32rpx 24rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--primary-pale);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.user-motto {
  margin-top: 4rpx;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 28rpx 16rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* 菜单列表 */
.menu-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.menu-item {
  padding: 24rpx;
  transition: transform 0.15s ease;
}

.menu-item:active {
  transform: scale(0.98);
}

.menu-icon {
  font-size: 36rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-pale);
  border-radius: 14rpx;
  flex-shrink: 0;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.menu-desc {
  margin-top: 2rpx;
}

.arrow {
  font-size: 36rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}
