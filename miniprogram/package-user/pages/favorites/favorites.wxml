<view class="page">
  <view class="list">
    <view class="fav-item card" wx:for="{{favorites}}" wx:key="_id" data-item="{{item}}" bindtap="onItemTap" bindlongpress="onUnfavorite">
      <view class="flex-between">
        <view class="flex-1">
          <view class="fav-header flex-row gap-sm">
            <text class="tag">{{item.typeLabel || '题目'}}</text>
            <text class="text-sm text-hint" wx:if="{{item.subjectName}}">{{item.subjectName}}</text>
          </view>
          <view class="fav-content mt-sm">{{item.title || item.summary || item.questionText || '暂无摘要'}}</view>
        </view>
        <view class="fav-star">⭐</view>
      </view>
    </view>
  </view>

  <view wx:if="{{loadingMore}}" class="load-more">
    <text class="text-hint text-sm">加载中…</text>
  </view>
  <view wx:if="{{noMore && favorites.length > 0}}" class="load-more">
    <text class="text-hint text-sm">— 已经到底了 —</text>
  </view>

  <empty-state wx:if="{{!loading && favorites.length === 0}}" title="收藏喜欢的题目" subtitle="随时温习"></empty-state>

  <view wx:if="{{loading}}" class="skeleton-list">
    <view class="card skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
      <view class="skeleton skeleton-tag"></view>
      <view class="skeleton skeleton-text mt-sm"></view>
    </view>
  </view>
</view>
