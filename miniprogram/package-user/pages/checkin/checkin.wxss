.page { padding: 24rpx; min-height: 100vh; }

/* 积分总览 */
.points-hero {
  text-align: center;
  padding: 48rpx 24rpx;
  background: linear-gradient(135deg, #5B8C7E 0%, #7BA89D 100%);
  color: #fff;
  border-radius: var(--radius);
  margin-bottom: 24rpx;
}

.points-num {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1.1;
}

.points-label {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.streak-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.25);
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  margin-top: 20rpx;
}

.streak-fire { font-size: 28rpx; }

/* 签到按钮 */
.checkin-btn-wrap { margin-bottom: 24rpx; }

.checkin-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: var(--primary);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius);
  border: none;
}

.checkin-btn::after { border: none; }

.checkin-btn.checked {
  background: #e0e0e0;
  color: var(--text-hint);
}

/* 日历 */
.calendar {
  padding: 28rpx 20rpx;
  margin-bottom: 24rpx;
}

.calendar-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 20rpx;
}

.calendar-week {
  display: flex;
  margin-bottom: 12rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-hint);
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.cal-cell {
  width: calc(100% / 7);
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cal-cell.empty { visibility: hidden; }

.cal-day {
  font-size: 28rpx;
  color: var(--text-primary);
}

.cal-check {
  font-size: 20rpx;
  color: var(--primary);
  margin-top: 2rpx;
}

.cal-cell.checked .cal-day {
  color: var(--primary);
  font-weight: 600;
}

.cal-cell.today {
  background: var(--primary-pale);
  border-radius: 12rpx;
}

.cal-cell.today .cal-day {
  color: var(--primary);
  font-weight: 700;
}

/* 规则 */
.rules { padding: 28rpx 24rpx; }

.rules-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.rule-item:last-child { border-bottom: none; }

.rule-icon { font-size: 32rpx; margin-right: 16rpx; }

.rule-text { flex: 1; font-size: 28rpx; color: var(--text-primary); }

.rule-points {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}
