<view class="page">
  <!-- 顶部科目tab -->
  <scroll-view class="tabs" scroll-x enable-flex wx:if="{{subjects.length > 0}}">
    <view class="tab {{activeSubjectId === item._id ? 'active' : ''}}"
      wx:for="{{subjects}}" wx:key="_id"
      data-id="{{item._id}}"
      bindtap="onTabTap">{{item.name}}</view>
  </scroll-view>

  <!-- 操作栏 -->
  <view class="action-bar" wx:if="{{errors.length > 0}}">
    <view class="error-count text-sm text-hint">共 {{errors.length}} 道错题</view>
    <view class="clear-btn text-sm text-danger" bindtap="onClearAll">清空</view>
  </view>

  <!-- 错题列表 -->
  <view class="list">
    <view class="error-item {{activeDeleteId === item._id ? 'swiped' : ''}}"
      wx:for="{{errors}}" wx:key="_id"
      data-id="{{item._id}}"
      data-item="{{item}}"
      bindtap="onItemTap"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindlongpress="onLongPress">
      <view class="error-main">
        <view class="error-type tag">{{item.typeLabel || '题目'}}</view>
        <view class="error-content">{{item.title || item.summary || item.questionText || '暂无摘要'}}</view>
        <view class="flex-row gap-md mt-sm">
          <text class="text-sm text-hint">错误 {{item.errorCount || 1}} 次</text>
          <text class="text-sm text-hint" wx:if="{{item.lastErrorTime}}">{{item.lastErrorTime}}</text>
        </view>
      </view>
      <view class="delete-area" catchtap="onDeleteItem" data-item="{{item}}">
        <text>移除</text>
      </view>
    </view>
  </view>

  <view wx:if="{{loadingMore}}" class="load-more">
    <text class="text-hint text-sm">加载中…</text>
  </view>
  <view wx:if="{{noMore && errors.length > 0}}" class="load-more">
    <text class="text-hint text-sm">— 已经到底了 —</text>
  </view>

  <empty-state wx:if="{{!loading && errors.length === 0}}" title="每道错题都是进步的阶梯" subtitle="去练习页面做几道题吧"></empty-state>

  <view wx:if="{{loading}}" class="skeleton-list">
    <view class="card skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
      <view class="skeleton skeleton-tag"></view>
      <view class="skeleton skeleton-text mt-sm"></view>
      <view class="skeleton skeleton-sub mt-sm"></view>
    </view>
  </view>
</view>
