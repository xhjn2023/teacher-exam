.page {
  padding: 20rpx 24rpx;
  min-height: 100vh;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.menu-item {
  padding: 24rpx;
  transition: transform 0.15s ease;
}

.menu-item:active {
  transform: scale(0.98);
}

.menu-icon {
  font-size: 36rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-pale);
  border-radius: 14rpx;
  flex-shrink: 0;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.menu-desc {
  margin-top: 2rpx;
}

.arrow {
  font-size: 36rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

.action-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid var(--primary);
  color: var(--primary);
  flex-shrink: 0;
}

.action-btn:active {
  background: var(--primary-pale);
}

/* 底部 */
.footer {
  padding: 60rpx 0 40rpx;
}

.footer-logo {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.footer-motto {
  margin-top: 8rpx;
}
