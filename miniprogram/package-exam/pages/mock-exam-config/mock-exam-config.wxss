.page {
  padding: 28rpx 24rpx;
  min-height: 100vh;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section {
  padding: 28rpx 24rpx;
}

.section-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.picker-view {
  padding: 16rpx 20rpx;
  background: var(--bg-page);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.picker-arrow {
  font-size: 22rpx;
  color: var(--text-hint);
}

.slider-wrap {
  padding: 4rpx 0;
}

.slider-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-top: 12rpx;
}

.count-num {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1;
}

.count-unit {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}

/* 说明 */
.tips {
  padding: 24rpx;
}

.tip-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.tip-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 开始按钮 */
.start-btn {
  margin-top: 20rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border-radius: var(--radius);
}

.center-loading {
  display: flex;
  justify-content: center;
  padding-top: 120rpx;
}
